# Firebase web app config (from Firebase Console > Project settings > Your apps).
# Copy this file to .env.local and fill in real values. These are not secrets.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to 1 to use the local Firebase emulators (free, offline dev).
VITE_USE_EMULATOR=1
